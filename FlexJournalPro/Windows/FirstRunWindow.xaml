<Window x:Class="FlexJournalPro.Windows.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ЖурналПро - Перший запуск" 
        Width="680"
        MinHeight="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Border CornerRadius="8" Background="{DynamicResource MaterialDesign.Brush.Background}" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}">
        <Grid>
            <!-- Щоб відступи і загальна динаміка працювали правильно, використовуємо RowDefinitions -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Вміст -->
            </Grid.RowDefinitions>

            <!-- 1. Title Bar -->
            <Border Grid.Row="0" Height="32" Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Перший запуск - Ласкаво просимо!" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                    <Button Click="CloseButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Width="24" Height="24" Padding="0">
                        <materialDesign:PackIcon Kind="Close" Foreground="White" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 2. Main Content Area -->
            <!-- Замінюємо внутрішній Grid на StackPanel (щоб уникнути перекриття при SizeToContent) або залишаємо Grid з правильними Auto -->
            <StackPanel Grid.Row="1" Margin="24">
                
                <!-- Логотип та заголовок -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                    <materialDesign:PackIcon Kind="BookOpenPageVariant" Width="72" Height="72" 
                             VerticalAlignment="Center" 
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                             Margin="0,0,16,0"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ЖурналПро" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" HorizontalAlignment="Left"/>
                        <TextBlock Text="Система управління журналами" FontSize="12" Opacity="0.7" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>

                <!-- Основна форма: Логін і шифрування -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ліва колонка: Обліковий запис -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,16,0">
                        <TextBlock Text="Обліковий запис" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,8"/>

                        <TextBox x:Name="LoginTextBox"
                                 materialDesign:HintAssist.Hint="Логін адміністратора"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Account"
                                 materialDesign:TextFieldAssist.LeadingIconSize="22"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,8,0,0" FontSize="16" />

                        <PasswordBox x:Name="PasswordBox"
                                     materialDesign:HintAssist.Hint="Пароль"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                     materialDesign:TextFieldAssist.LeadingIconSize="22"
                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                     Margin="0,24,0,0" FontSize="16" />

                        <PasswordBox x:Name="PasswordBox2"
                                     materialDesign:HintAssist.Hint="Підтвердження пароля"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="LockCheck"
                                     materialDesign:TextFieldAssist.LeadingIconSize="22"
                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                     Margin="0,24,0,0" FontSize="16" />
                    </StackPanel>

                    <!-- Права колонка: Безпека -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="16,0,0,0">
                        <TextBlock Text="Безпека даних" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,8"/>

                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton Grid.Column="0"
                                          x:Name="UseEncryptionSwitch" 
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}" 
                                          IsChecked="True" 
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <ToggleButton.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.75" ScaleY="0.75"/>
                                </TransformGroup>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <TextBlock Grid.Column="1"
                                   Text="Використовувати шифрування даних (рекомендовано)" 
                                   Margin="12,0,0,0" 
                                   FontSize="14" 
                                   VerticalAlignment="Center" 
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="0,0,0,16"
                          Visibility="{Binding IsChecked, ElementName=UseEncryptionSwitch, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="ShieldAlert" Width="24" Height="24" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" 
                                   Text="При увімкненому шифруванні буде створено майстер-ключ. Це ЄДИНИЙ спосіб відновлення доступу до даних!" 
                                   FontSize="12" 
                                   Opacity="0.8" 
                                   TextWrapping="Wrap" 
                                   VerticalAlignment="Top"/>
                    </Grid>
                </StackPanel>
                </Grid>

                <!-- Блок з ключем (Динамічно ховається/показується) -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Surface}" 
                        BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}" 
                        BorderThickness="1" CornerRadius="6" Padding="16,12"
                        Margin="0,16,0,0"
                        Visibility="Collapsed"
                        x:Name="MasterKeyBlock">
                    <StackPanel>
                        <TextBlock Text="ВАШ МАЙСТЕР-КЛЮЧ ВІДНОВЛЕННЯ:" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,8" FontWeight="SemiBold"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="MasterDekTextBlock" 
                                       Grid.Column="0"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"
                                       Margin="0,0,16,0" TextAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="CopyKeyButton"
                                        Click="CopyKeyButton_Click"
                                        Style="{StaticResource MaterialDesignIconButton}" 
                                        ToolTip="Скопіювати в буфер обміну"
                                        Width="32" Height="32" Padding="0"
                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                    <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                </Button>

                                <Button x:Name="SaveKeyButton"
                                        Click="SaveKeyButton_Click"
                                        Style="{StaticResource MaterialDesignIconButton}" 
                                        ToolTip="Зберегти ключ у файл"
                                        Width="32" Height="32" Padding="0" Margin="8,0,0,0"
                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Фінальна кнопка і помилки -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0">
                    <TextBlock x:Name="ErrorTextBlock" 
                               Foreground="Red" 
                               Margin="0,0,0,16" 
                               Visibility="Collapsed" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Button Content="РОЗПОЧАТИ" 
                            Click="LoginButton_Click"
                            Height="44"
                            IsDefault="True"
                            FontSize="14"
                            FontWeight="Bold"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>