<UserControl x:Class="FlexJournalPro.Views.Screens.UserEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:FlexJournalPro.Models"
             xmlns:helpers="clr-namespace:FlexJournalPro.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="1" Padding="0">
            <TabControl materialDesign:ColorZoneAssist.Mode="PrimaryLight" Style="{StaticResource MaterialDesignTabControl}">
                <TabItem Header="Основне">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Обліковий запис" 
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                           Margin="0,0,0,12"/>

                                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="Логін" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0,0,0,16"/>

                                <PasswordBox materialDesign:HintAssist.Hint="Пароль" 
                                             Margin="0,0,0,16"
                                             helpers:PasswordHelper.Attach="True"
                                             helpers:PasswordHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignFloatingHintPasswordBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="materialDesign:HintAssist.HelperText" Value="Залиште порожнім, якщо не хочете змінювати" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>

                                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="ПІБ (Повне ім'я)" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         Margin="0,0,0,16"/>
                            </StackPanel>

                            <Separator Margin="0,0,0,20"/>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Роль користувача" 
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                           Margin="0,0,0,12"/>

                                <ComboBox SelectedItem="{Binding Role}"
                                          materialDesign:HintAssist.Hint="Роль користувача"
                                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                          Margin="0,0,0,16">
                                    <models:UserRole>Viewer</models:UserRole>
                                    <models:UserRole>Editor</models:UserRole>
                                    <models:UserRole>Admin</models:UserRole>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Керування доступом" Visibility="{Binding IsJournalSelectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Доступні журнали" 
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="Виділіть журнали та використовуйте стрілки для надання або відкликання доступу користувача." 
                                   Foreground="Gray" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Доступні" 
                                      Style="{DynamicResource MaterialDesignCardGroupBox}"
                                      materialDesign:ColorZoneAssist.Mode="Standard">
                                <ListBox ItemsSource="{Binding AvailableJournals}" 
                                         SelectedItem="{Binding SelectedAvailableJournal}"
                                         DisplayMemberPath="Title"
                                         Margin="4"/>
                            </GroupBox>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                                <Button Command="{Binding AddJournalCommand}" 
                                        ToolTip="Додати вибраний запис"
                                        Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="ChevronRight" />
                                </Button>
                                <Button Command="{Binding AddAllJournalsCommand}" 
                                        ToolTip="Додати всі записи"
                                        Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,0,24">
                                    <materialDesign:PackIcon Kind="ChevronDoubleRight" />
                                </Button>

                                <Button Command="{Binding RemoveJournalCommand}" 
                                        ToolTip="Видалити вибраний запис"
                                        Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="ChevronLeft" />
                                </Button>
                                <Button Command="{Binding RemoveAllJournalsCommand}" 
                                        ToolTip="Видалити всі записи"
                                        Style="{StaticResource MaterialDesignIconButton}">
                                    <materialDesign:PackIcon Kind="ChevronDoubleLeft" />
                                </Button>
                            </StackPanel>

                            <GroupBox Grid.Column="2" Header="Має доступ"
                                      Style="{DynamicResource MaterialDesignCardGroupBox}"
                                      materialDesign:ColorZoneAssist.Mode="Standard">
                                <ListBox ItemsSource="{Binding SelectedJournals}" 
                                         SelectedItem="{Binding SelectedAssignedJournal}"
                                         DisplayMemberPath="Title"
                                         Margin="4"/>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Скасувати" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Margin="0,0,16,0"/>

                <Button Content="Зберегти" 
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>