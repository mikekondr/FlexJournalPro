<UserControl x:Class="FlexJournalPro.Views.Screens.NewJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800"
             SizeChanged="UserControl_SizeChanged">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="1" Padding="24">
            <!-- Єдиний ScrollViewer для всього вмісту екрану -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    
                    <!-- 1. Блок на повну ширину екрану -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Шаблон журналу" 
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                   Margin="0,0,0,12"/>
                        <ComboBox ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplate}"
                                  materialDesign:HintAssist.Hint="Оберіть шаблон..."
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Версія: " FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Version}" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text=" | " FontSize="11" Foreground="Gray" Margin="5,0"/>
                                            <TextBlock Text="ID: " FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Id}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- 2. Блок, який розділяється на дві колонки на великих екранах -->
                    <Grid x:Name="SplitGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="LeftCol"/>
                            <ColumnDefinition Width="Auto" x:Name="SplitterCol"/>
                            <ColumnDefinition Width="*" x:Name="RightCol"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Ліва панель (Налаштування) -->
                        <StackPanel x:Name="LeftContent" Grid.Row="0" Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Налаштування журналу" 
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding JournalTitle, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Назва" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     Margin="0,0,0,16"/>
                            <TextBox Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="Початковий номер" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                            <!-- Розділювач для мобільного/вузького вигляду -->
                            <Separator Margin="0,24,0,8" x:Name="AdaptiveSeparator" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Вертикальний розділювач -->
                        <GridSplitter x:Name="VerticalSplitter" Grid.Row="0" Grid.Column="1" 
                                      Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                                      Background="LightGray"
                                      ShowsPreview="True"/>

                        <!-- Права панель (Параметри) -->
                        <StackPanel x:Name="RightContent" Grid.Row="0" Grid.Column="2" Margin="16,0,0,0">
                            <TextBlock Text="Параметри заповнення" 
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                       Margin="0,0,0,12"/>

                            <StackPanel x:Name="DynamicAutoFillPanel" Margin="0,0,0,10" />

                            <TextBlock Text="Оберіть шаблон для відображення параметрів" 
                                       Foreground="Gray" 
                                       HorizontalAlignment="Center"
                                       Margin="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAutoFillParams}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Скасувати" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Margin="0,0,16,0"/>
                <Button Content="Створити" 
                        Command="{Binding CreateJournalCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
