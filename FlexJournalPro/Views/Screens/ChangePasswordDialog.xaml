<UserControl x:Class="FlexJournalPro.Views.ChangePasswordDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:FlexJournalPro.Helpers"
             xmlns:converters="clr-namespace:FlexJournalPro.Converters"
             Width="350">
    
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    
    <StackPanel Margin="20">
        <TextBlock Text="Зміна пароля" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

        <PasswordBox materialDesign:HintAssist.Hint="Старий пароль"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     helpers:PasswordHelper.Attach="True"
                     helpers:PasswordHelper.Password="{Binding OldPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,15" />

        <PasswordBox materialDesign:HintAssist.Hint="Новий пароль"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     helpers:PasswordHelper.Attach="True"
                     helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,15" />

        <PasswordBox materialDesign:HintAssist.Hint="Підтвердіть новий пароль"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                     helpers:PasswordHelper.Attach="True"
                     helpers:PasswordHelper.Password="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,15" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"
                   HorizontalAlignment="Stretch"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=True}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Скасувати" Command="{Binding CancelCommand}" 
                    Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" />
            <Button Content="Змінити" Command="{Binding ChangeCommand}" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</UserControl>